{
  "name": "pixel-agents-web",
  "version": "1.0.0",
  "description": "Standalone web wrapper for the original pablodelucca Pixel Agents VS Code extension with OpenCode and Claude Code session discovery.",
  "private": true,
  "scripts": {
    "dev": "node scripts/network.mjs --dev",
    "network": "node scripts/network.mjs",
    "build": "next build",
    "start": "node scripts/network.mjs",
    "dev:web": "next dev -p 4555",
    "start:web": "next start -p 4555"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
